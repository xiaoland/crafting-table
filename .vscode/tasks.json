{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Launch CraftingTable on iPad",
      "type": "shell",
      "command": "./scripts/launch-ipad-device.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Launch CraftingTable in iPad Simulator",
      "type": "shell",
      "command": "./scripts/launch-ipad-simulator.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
