{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crafting Table",
  "version": "0.1.0",
  "identifier": "dev.lanzhijiang.CraftingTable.windows",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Crafting Table",
        "label": "main",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "../../apple/iPad/Assets.xcassets/AppIcon.appiconset/AppIcon.png"
    ]
  }
}
